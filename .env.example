# Pet Clinic ERP — Environment Variables
# Copy this to .env and fill in your actual values

DB_HOST=localhost
DB_PORT=5432
DB_NAME=pet_erp
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

SECRET_KEY=your_secret_key_here_make_it_very_long_and_random_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
